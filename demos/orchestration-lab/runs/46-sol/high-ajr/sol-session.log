library(ivdoctr); library(AER); data(colonial, package=\"ivdoctr\"); d <- as.data.frame(colonial)
specs <- list(Base=list(rows=rep(TRUE,nrow(d)),controls=character()), Latitude=list(rows=rep(TRUE,nrow(d)),controls=\"lat_abst\"), Continent=list(rows=rep(TRUE,nrow(d)),controls=c(\"africa\",\"asia\")), DropNeo=list(rows="'!d$shortnam %in% c("AUS","CAN","NZL","USA"),controls=character()), Africa=list(rows=d$africa==1,controls=character()))
for (nm in names(specs)) { s <- specs[[nm]]; x <- d[s$rows,,drop=FALSE]; vars <- c("logpgp95","avexpr","logem4",s$controls); x <- x[complete.cases(x[,vars,drop=FALSE]),,drop=FALSE]; rhs1 <- paste(c("avexpr",s$controls),collapse="+"); rhsz <- paste(c("logem4",s$controls),collapse="+"); ols <- lm(as.formula(paste("logpgp95~",rhs1)),data=x); iv <- ivreg(as.formula(paste("logpgp95~",rhs1,"|",rhsz)),data=x); fs <- lm(as.formula(paste("avexpr~",rhsz)),data=x); f <- coef(summary(fs))["logem4","t value"]''^2; cat(sprintf("%-9s N=%d OLS=%.9f IV=%.9f FS=%.9f F=%.9f'"\\n\",nm,nrow(x),coef(ols)[[\"avexpr\"]],coef(iv)[[\"avexpr\"]],coef(fs)[[\"logem4\"]],f)) }
