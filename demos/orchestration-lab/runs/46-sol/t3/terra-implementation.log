+
+housing_l2_l1 <- housing_contrasts[housing_contrasts$chosen == "level2" & housing_contrasts$baseline == "level1", ]
+housing_l1_l3 <- housing_contrasts[housing_contrasts$chosen == "level1" & housing_contrasts$baseline == "level3", ]
