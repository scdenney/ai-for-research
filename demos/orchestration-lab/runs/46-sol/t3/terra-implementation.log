+plot(NA, xlim = c(0.25, 0.75), ylim = c(7.6, 0.4), yaxt = "n", xlab = "Corrected marginal mean (choice probability)", ylab = "")
+abline(v = 0.5, lty = 2, col = "#666666", lwd = 1.2)
+for (i in seq_along(attribute_order)) {
