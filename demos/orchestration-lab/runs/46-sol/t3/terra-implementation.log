+  fmt_ci_pp(crime_more_less), fmt_ci_pp(crime_less_more), fmt_mm(crime_mm[1, ]),
+  fmt_mm(crime_mm[2, ]), 100 * crime_range, fmt_ci_pp(housing_l2_l1),
