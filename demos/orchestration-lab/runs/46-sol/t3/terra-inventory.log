run('housing AMCE levels1/3 versus level2', projoint(pj, .qoi=q_housing_l2, .se_method='analytical'))
q_bad <- set_qoi(.structure='profile_level', .estimand='amce', .att_choose='att7', .lev_choose='att7:level2', .att_choose_b='att7', .lev_choose_b='att7:level1')
run('negative control: full level ids supplied to QoI', projoint(pj,.qoi=q_bad,.se_method='analytical'))
