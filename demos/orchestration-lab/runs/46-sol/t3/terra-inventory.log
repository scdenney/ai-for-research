run <- function(label, expr) {
 cat('\\n===', label, '===\\n')
 ans <- tryCatch(eval.parent(substitute(expr)), error=function(e)e)
 if(inherits(ans,'error')) {cat('ERROR:',conditionMessage(ans),'\\n'); return(invisible(NULL))}
 cat('class:',paste(class(ans),collapse=', '),'\\n')
 cat('estimand:',ans"'$estimand,'"' structure:',ans"'$structure,'"' cluster_by:',ans"'$cluster_by,'"' se:',ans"'$se_type_used,'"' irr:',ans"'$irr,'"' tau:',ans"'$tau,'"'\\n')
 print(ans"'$estimates, n=Inf)
}
run('"'all profile-level MMs', projoint(pj, .structure='profile_level', .estimand='mm', .se_method='analytical'))
run('all profile-level AMCEs, implicit level1 baseline', projoint(pj, .structure='profile_level', .estimand='amce', .se_method='analytical'))
