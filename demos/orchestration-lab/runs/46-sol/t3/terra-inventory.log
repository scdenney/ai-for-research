=== set_qoi body ===
function (.structure = "choice_level", .estimand = "mm", .att_choose, 
    .lev_choose, .att_notchoose = NULL, .lev_notchoose = NULL, 
    .att_choose_b = NULL, .lev_choose_b = NULL, .att_notchoose_b = NULL, 
    .lev_notchoose_b = NULL) 
{
    structure <- rlang::arg_match0(.structure, c("choice_level", 
        "profile_level"))
    estimand <- rlang::arg_match0(.estimand, c("mm", "amce"))
    projoint_qoi(structure = structure, estimand = estimand, 
        attribute_of_interest = .att_choose, levels_of_interest = .lev_choose, 
        attribute_of_interest_0 = .att_notchoose, levels_of_interest_0 = .lev_notchoose, 
        attribute_of_interest_baseline = .att_choose_b, levels_of_interest_baseline = .lev_choose_b, 
        attribute_of_interest_0_baseline = .att_notchoose_b, 
        levels_of_interest_0_baseline = .lev_notchoose_b)
}
