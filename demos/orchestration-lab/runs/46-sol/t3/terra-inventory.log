options(width=200)
library(projoint)
data(exampleData1)
out <- reshape_projoint(exampleData1, .outcomes=c(paste0('choice',1:8),'choice1_repeated_flipped'))
d <- out"'$data; lab <- out$labels
cat('"'=== OBSERVED LABEL MAP ===\\n')
print(lab, n=Inf)
cat('\\n=== OBSERVED DATA COLUMNS/LEVELS ===\\n')
for(nm in names(d)) {
 x <- d[[nm]]
 cat(nm, '|', paste(class(x),collapse='/'), '|')
 if(is.factor(x)) cat('levels=', paste(levels(x),collapse=', '))
 else cat('unique=', length(unique(x)), 'NA=', sum(is.na(x)))
 cat('\\n')
