+  if (anyNA(control_ids) || any(!treated_ids %in% rownames(dat)) || any(!control_ids %in% rownames(dat))) {
+    stop("Matching matrix has missing or unrecognized original unit IDs.")
+  }
+  d <- dat[treated_ids, "re78"] - dat[control_ids, "re78"]
