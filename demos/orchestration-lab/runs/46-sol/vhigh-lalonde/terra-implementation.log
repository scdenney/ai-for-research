+
+money <- function(x) paste0("$", format(round(x), big.mark = ",", trim = TRUE, scientific = FALSE))
+int_money <- function(lo, hi) paste0("[", money(lo), ", ", money(hi), "]")
+table_lines <- c(
+  "# Fixed LaLonde specification curve",
+  "",
+  "Outcome: 1978 earnings (USD). The experimental NSW treated-minus-control benchmark is recomputed from the NSW sample. Naive interval is Welch; matching intervals are approximate CR1 intervals conditional on fitted scores; subclassification intervals are Neyman fixed-strata intervals.",
