+make_row <- function(label, estimate, se, covariates, support, estimator, n_treated, n_control) {
+  data.frame(
+    specification = label,
+    estimate = estimate,
+    se = se,
+    lower = estimate - z975 * se,
+    upper = estimate + z975 * se,
