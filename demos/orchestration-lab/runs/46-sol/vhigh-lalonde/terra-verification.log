/bin/zsh -lc "Rscript - <<'RS'
suppressPackageStartupMessages({library(causaldata); library(MatchIt); library(sandwich)})
nsw <- as.data.frame(nsw_mixtape); cps <- as.data.frame(cps_mixtape)
tr <- nsw[nsw"'$treat==1,]; co <- cps[cps$treat==0,]
tr$unit_id <- sprintf('"'nsw_t_%03d', seq_len(nrow(tr))); co"'$unit_id <- sprintf('"'cps_c_%05d', seq_len(nrow(co)))
obs <- rbind(tr,co); rownames(obs)<-obs"'$unit_id
