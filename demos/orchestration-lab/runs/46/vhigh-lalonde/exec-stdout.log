+ggsave("figures/spec-curve.png", p, width = 10, height = 6.2, dpi = 320)
+
+money <- function(x) formatC(x, format = "f", digits = 0, big.mark = ",")
+table_lines <- c(
+  "# Specification table", "",
+  sprintf("Experimental benchmark (NSW treated − NSW control): **$%s**.", money(benchmark)), "",
